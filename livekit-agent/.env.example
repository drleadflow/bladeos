# ── LiveKit Cloud ────────────────────────────────────────
# Must match the credentials used by apps/web token endpoint
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── AI Providers ────────────────────────────────────────
# Google Gemini (required — powers the LLM)
GOOGLE_API_KEY=

# Deepgram (required — speech-to-text)
DEEPGRAM_API_KEY=

# Cartesia (required — text-to-speech)
CARTESIA_API_KEY=

# ── Blade Backend API ───────────────────────────────────
# URL of the running apps/web backend
BLADE_API_URL=http://localhost:3000
# Auth token (must match AUTH_SECRET in apps/web .env)
BLADE_API_TOKEN=

# ── Optional Tool Integrations ──────────────────────────
# Meta Ads (for ad performance tools)
META_USER_TOKEN=

# Web search (for web_search tool)
TAVILY_API_KEY=

# GitHub (for github_list_issues, github_get_pr tools)
GITHUB_TOKEN=

# Telegram (for send_to_telegram tool)
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
