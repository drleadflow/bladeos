# ============================================================
# Blade Super Agent — Environment Configuration
# Copy to .env and fill in your keys
# ============================================================

# ── AI Providers (at least one required) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
OPENROUTER_API_KEY=sk-or-...

# ── Web Search (optional) ────────────────────────────────────
EXA_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=

# ── GitHub (required for coding pipeline) ────────────────────
GITHUB_TOKEN=ghp_...

# ── GoHighLevel (leads pipeline) ─────────────────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_MCP_USER_KEY=

# ── Meta / Facebook / Instagram ──────────────────────────────
META_USER_TOKEN=
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_WEBHOOK_URL=

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_DEFAULT_MAX_RESULTS=50

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Airtable ─────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_CONTENT_API_KEY=
AIRTABLE_PAT=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Apify (social analytics) ────────────────────────────────
APIFY_API_KEY=

# ── War Room Voice ───────────────────────────────────────────
# Pipecat server WebSocket URL (used by the Next.js frontend)
NEXT_PUBLIC_WARROOM_WS_URL=ws://localhost:7860
# Voice proxy settings (warroom/proxy.py)
VOICE_PROXY_PORT=7861
PIPECAT_URL=ws://localhost:7860

# ── Voice / Audio ────────────────────────────────────────────
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
CARTESIA_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Video / AI Media ────────────────────────────────────────
HEYGEN_API_KEY=
SUBMAGIC_API_KEY=
RUNWAY_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=
WAVESPEED_API_KEY=

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── Slack ────────────────────────────────────────────────────
SLACK_ACCESS_TOKEN=

# ── Twitter / X ──────────────────────────────────────────────
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# ── Email ────────────────────────────────────────────────────
RESEND_API_KEY=
FINDYMAIL_API_KEY=

# ── Automation ───────────────────────────────────────────────
N8N_API_KEY=
ZAPIER_MCP_TOKEN=

# ── Hosting / Infra ─────────────────────────────────────────
VERCEL_API_TOKEN=
NGROK_API_KEY=

# ── Web UI ───────────────────────────────────────────────────
PORT=3000
AUTH_SECRET=generate-a-random-string-here

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=file:./blade.db
