# Blade Super Agent Configuration

# Required: At least one AI provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional: OpenRouter for 200+ models
OPENROUTER_API_KEY=sk-or-...

# Optional: Gemini
GEMINI_API_KEY=

# Optional: Web search providers
EXA_API_KEY=
SERPAPI_API_KEY=
TAVILY_API_KEY=

# GoHighLevel MCP Server
GHL_MCP_USER_KEY=

# GitHub (required for coding pipeline)
GITHUB_TOKEN=ghp_...

# Voice (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Web UI
PORT=3000
AUTH_SECRET=generate-a-random-string-here

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Database (default: local SQLite)
DATABASE_URL=file:./blade.db
