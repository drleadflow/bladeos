# Backend API (use http://localhost:3000 for local dev)
VITE_API_URL=https://your-railway-url.up.railway.app

# War Room WebSocket (optional, for Pipecat mode)
VITE_VOICE_WS_URL=wss://your-railway-url.up.railway.app:7861

# Auth token (must match AUTH_SECRET from apps/web .env)
VITE_BLADE_TOKEN=your-auth-token-here

# LiveKit Cloud URL (must match LIVEKIT_URL in livekit-agent/.env)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
